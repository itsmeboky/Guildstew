            "system": {
                "actionType": {
                    "value": "reaction"
                },
                "actions": {
                    "value": null
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Trigger</strong> Aezar succeeds at a greataxe Strike against a creature</p><hr /><p><strong>Effect</strong> Aezar's axe has a lingering residue from striking various sweets, and the sticky blade clings to her most recent victim, giving Aezar momentary leverage. Aezar can attempt to [[/act reposition]] or [[/act trip]] the target using the greataxe's reach, even though she doesn't have a free hand.</p>\n<p>Alternatively, she can forgo either maneuver to drag the target toward her gaping mouth, granting her jaws unarmed Strike the agile trait for attacks made against the target until the end of her turn.</p>"
                },
                "publication": {
