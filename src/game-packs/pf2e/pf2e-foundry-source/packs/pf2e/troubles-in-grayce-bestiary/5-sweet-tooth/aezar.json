        {
            "_id": "LLR9slzjCEq4kwg9",
            "img": "systems/pf2e/icons/actions/Passive.webp",
            "name": "Tooth Decay",
            "sort": 600000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "defensive",
                "description": {
                    "value": "<p>Frequent candy consumption has worsened Aezar's already poor dental health. If she takes 10 or more bludgeoning damage from a single attack or effect, she must attempt a @Check[fortitude|dc:25] save.</p><hr /><p><strong>Success</strong> Aezar yells in pain but is otherwise unaffected.</p>\n<p><strong>Failure</strong> Several of Aezar's teeth break. She takes a –2 penalty to damage with her jaws Strike as well as to Athletics checks made as part of her @UUID[Compendium.pf2e.bestiary-ability-glossary-srd.Item.Grab] and @UUID[Compendium.pf2e.bestiary-ability-glossary-srd.Item.Swallow Whole] abilities. These penalties last until Aezar is restored to her Hit Point maximum.</p>\n<p><strong>Critical Failure</strong> As failure, but so many of Aezar's teeth break that the penalty increases to –3 and she takes @Damage[(1d6-2)[persistent,bleed]] damage.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [
                    {
                        "key": "RollOption",
                        "option": "tooth-decay",
                        "toggleable": true
                    },
                    {
                        "key": "FlatModifier",
                        "predicate": [
                            "tooth-decay"
                        ],
                        "selector": [
                            "jaws-damage"
                        ],
                        "value": -2
                    },
                    {
                        "key": "FlatModifier",
                        "predicate": [
                            "tooth-decay",
                            {
                                "or": [
                                    "action:swallow-whole",
                                    "action:grapple"
                                ]
                            }
                        ],
                        "selector": [
                            "athletics"
                        ],
                        "value": -2
                    },
                    {
                        "key": "Note",
                        "predicate": [
                            "item:damage:type:bludgeoning"
                        ],
                        "selector": [
                            "damage-received"
                        ],
                        "text": "{item|description}",
                        "title": "{item|name}",
                        "visibility": "owner"
                    }
                ],
