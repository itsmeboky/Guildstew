        {
            "_id": "GPSIIphSLmhgakBd",
            "img": "systems/pf2e/icons/actions/OneAction.webp",
            "name": "Frightful Snarl",
            "sort": 1000000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p>Krethark snarls and glares at a creature within 30 feet that he can see, and then attempts to [[/act demoralize]] that creature; he doesn't take a penalty if the creature doesn't understand his language. A creature that becomes frightened by Frightful Snarl is @UUID[Compendium.pf2e.conditionitems.Item.Off-Guard] until the start of their turn.</p>"
                },
