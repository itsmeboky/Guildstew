        },
        {
            "_id": "ZnfkRNrbkTq6092K",
            "_stats": {
                "compendiumSource": "Compendium.pf2e.bestiary-family-ability-glossary.Item.ixPqVlqLaYTB1b23"
            },
            "folder": "Gg8SQFKssgHH6OUz",
            "img": "systems/pf2e/icons/actions/OneAction.webp",
            "name": "Consume Flesh",
            "sort": 1300000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Requirements</strong> The ghoul is adjacent to the corpse of a creature that died within the last hour.</p><hr /><p><strong>Effect</strong> The ghoul devours a chunk of the corpse and regains @Damage[(1+(max(0,floor(@actor.level/2))))d6[healing]] Hit Points.</p>\n<p>It can regain Hit Points from any given corpse only once.</p>"
                },
