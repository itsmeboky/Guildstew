        {
            "_id": "H6f9A4x8fk2P9b6a",
            "img": "systems/pf2e/icons/actions/TwoActions.webp",
            "name": "Chopping Frenzy",
            "sort": 1200000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 2
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Requirements</strong> Alendreu is wielding an orc necksplitter in each hand</p><hr /><p><strong>Effect</strong> Alendreu lashes out with both axes. He attempts two Strikes, one with each necksplitter, each using his current multiple attack penalty. Both Strikes must have the same target, and the second strike takes a –2 penalty.</p>\n<p>If both hit, combine their damage and apply resistances and weaknesses only once, and the target becomes @UUID[Compendium.pf2e.conditionitems.Item.Off-Guard] from the fury of the blow until the start of their next turn. This counts as two attacks when calculating Alendreu's multiple attack penalty.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [
                    {
                        "key": "RollOption",
                        "label": "PF2E.NPCAbility.Alendreu.ChoppingFrenzy.ToggleLabel",
