        },
        {
            "_id": "iThujq9Fhag6Jad2",
            "img": "systems/pf2e/icons/actions/Passive.webp",
            "name": "Throat Grab",
            "sort": 300000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p>When the crawling hand succeeds at its claw Strike against a Medium or smaller creature, it can use this action immediately after to attempt to [[/act grapple]] the target. This Grapple doesn't apply or count toward the crawling hand's multiple attack penalty. A creature @UUID[Compendium.pf2e.conditionitems.Item.Grabbed] this way has difficulty speaking and must spend an extra action to perform any action that requires speaking, including casting spells.</p>"
                },
