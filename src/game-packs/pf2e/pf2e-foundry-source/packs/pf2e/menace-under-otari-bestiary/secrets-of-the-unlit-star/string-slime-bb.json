            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Tag Team",
            "sort": 400000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 2
                },
                "category": "offensive",
                "description": {
                    "value": "<p>The slime arcs acidic protoplasm to another string slime within 30 feet along a straight line. Each creature in that line takes @Damage[3d6[acid]] damage with a @Check[reflex|dc:16|basic|options:area-effect,inflicts:prone] save. A creature that fails its save is also knocked @UUID[Compendium.pf2e.conditionitems.Item.Prone].</p>"
