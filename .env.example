# Copy to `.env` (gitignored) and fill in. All VITE_* vars are inlined into
# the browser bundle at build time, so only put public/publishable values
# here — never a client secret or service-role key.

# Supabase (existing)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Drive picker (World Lore import → "Choose from Google Drive").
# All three are public/publishable and shipped to the browser. Lock the API
# key by HTTP referrer + to the Picker + Drive APIs in the Google Cloud
# console. Do NOT add the OAuth client *secret* — the picker uses the
# client-side token flow and never needs it. Leave any blank to hide the
# picker button (the paste-a-link flow still works).
#   CLIENT_ID — OAuth 2.0 Web client id (…-….apps.googleusercontent.com)
#   API_KEY   — API key (AIza…)
#   APP_ID    — the Cloud project NUMBER (Picker setAppId); required, or the
#               read of the picked file returns 403
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=
VITE_GOOGLE_APP_ID=
